# ===================================
# CONFIGURACIÓN BACKEND - ARACHIZ
# ===================================

# Puerto del servidor
PORT=3000

# Secretos de autenticación (genera valores únicos y seguros)
JWT_SECRET=supersecretarachiz
SESSION_SECRET=arachiz-session-secret-2024

# ===================================
# BASE DE DATOS - SUPABASE/POSTGRESQL
# ===================================
# DATABASE_URL: Usa el pooler con pgbouncer=true para evitar prepared statements
DATABASE_URL="postgresql://usuario:password@host:6543/database?pgbouncer=true&connection_limit=1&pool_timeout=0"

# DIRECT_URL: Usa la conexión directa (puerto 5432) para migraciones
DIRECT_URL="postgresql://usuario:password@host:5432/database"

# ===================================
# SUPABASE STORAGE
# ===================================
SUPABASE_URL="https://tu-proyecto.supabase.co"
SUPABASE_ANON_KEY="tu_anon_key_aqui"

# ===================================
# URLs DE LA APLICACIÓN
# ===================================
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000
VITE_SOCKET_URL=http://localhost:3000

# ===================================
# GOOGLE OAUTH (OPCIONAL)
# ===================================
# Para configurar: Ver docs/CONFIGURAR_GOOGLE_OAUTH.md
# 1. Ve a https://console.cloud.google.com/
# 2. Crea credenciales OAuth 2.0
# 3. Copia el Client ID y Client Secret aquí
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ===================================
# EPAYCO - PAGOS (OPCIONAL)
# ===================================
# Para pagos en Colombia: PSE, Nequi, Tarjetas
EPAYCO_PUBLIC_KEY=your_epayco_public_key_here
EPAYCO_PRIVATE_KEY=your_epayco_private_key_here
EPAYCO_P_CUST_ID_CLIENTE=your_epayco_customer_id_here
EPAYCO_TEST=true

# ===================================
# WOMPI - PAGOS (OPCIONAL)
# ===================================
# Para pagos en Colombia: Tarjetas, PSE, Nequi
# Obtén las credenciales en: https://dashboard.wompi.co/
WOMPI_PUBLIC_KEY=pub_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WOMPI_PRIVATE_KEY=prv_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WOMPI_INTEGRITY_KEY=prod_sign_test_xxxxxxxxxxxxxxxxxxxxxxxxy
WOMPI_MERCHANT_CODE=your_merchant_code_here

# ===================================
# HARDWARE ESP8266 (OPCIONAL)
# ===================================
HARDWARE_API_KEY=arachiz-esp-2024

# ===================================
# EMAIL - RECUPERACIÓN DE CONTRASEÑA (OPCIONAL)
# ===================================
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
