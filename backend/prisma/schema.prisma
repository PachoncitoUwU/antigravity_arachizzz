generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String               @id @default(cuid())
  userType        String
  fullName        String
  document        String               @unique
  email           String               @unique
  password        String
  avatarUrl       String?
  nfcUid          String?              @unique
  huellas         Int[]                @default([])
  createdAt       DateTime             @default(now())
  faceDescriptor  Float[]              @default([])
  asistencias     Asistencia[]         @relation("InstructorAsistencia")
  breakoutScore   BreakoutScore?
  excusas         Excusa[]
  fichasAdmin     Ficha[]              @relation("InstructorAdmin")
  fichasInst      FichaInstructor[]
  flappyScore     FlappyScore?
  materias        Materia[]            @relation("InstructorMaterias")
  memoryScore     MemoryScore?
  reactionScore   ReactionScore?
  registros       RegistroAsistencia[]
  snakeScore      SnakeScore?
  towerScore      TowerScore?
  userSkins       UserSkin[]
  wordleScore     WordleScore?
  fichasApr       Ficha[]              @relation("Aprendices")
  materiasEvitadas MateriaEvitada[]
}

model Ficha {
  id                String            @id @default(cuid())
  numero            String            @unique
  nivel             String
  centro            String
  jornada           String
  region            String            @default("")
  duracion          Int               @default(0)
  code              String            @unique
  createdAt         DateTime          @default(now())
  instructorAdminId String
  nombre            String            @default("Programa sin nombre")
  instructorAdmin   User              @relation("InstructorAdmin", fields: [instructorAdminId], references: [id])
  instructores      FichaInstructor[]
  horarios          Horario[]
  materias          Materia[]
  aprendices        User[]            @relation("Aprendices")
}

model FichaInstructor {
  id           String @id @default(cuid())
  role         String @default("invitado")
  fichaId      String
  instructorId String
  ficha        Ficha  @relation(fields: [fichaId], references: [id], onDelete: Cascade)
  instructor   User   @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@unique([fichaId, instructorId])
}

model Materia {
  id               String             @id @default(cuid())
  nombre           String
  tipo             String
  fichaId          String
  instructorId     String
  asistencias      Asistencia[]
  horarios         Horario[]
  excusas          Excusa[]
  ficha            Ficha              @relation(fields: [fichaId], references: [id], onDelete: Cascade)
  instructor       User               @relation("InstructorMaterias", fields: [instructorId], references: [id])
  materiasEvitadas MateriaEvitada[]
}

model Horario {
  id         String  @id @default(cuid())
  dia        String
  horaInicio String
  horaFin    String
  fichaId    String
  materiaId  String
  ficha      Ficha   @relation(fields: [fichaId], references: [id], onDelete: Cascade)
  materia    Materia @relation(fields: [materiaId], references: [id], onDelete: Cascade)
}

model Asistencia {
  id           String               @id @default(cuid())
  fecha        String
  activa       Boolean              @default(true)
  timestamp    DateTime             @default(now())
  materiaId    String
  instructorId String
  instructor   User                 @relation("InstructorAsistencia", fields: [instructorId], references: [id])
  materia      Materia              @relation(fields: [materiaId], references: [id], onDelete: Cascade)
  registros    RegistroAsistencia[]
}

model RegistroAsistencia {
  id           String     @id @default(cuid())
  presente     Boolean    @default(true)
  metodo       String     @default("manual")
  timestamp    DateTime   @default(now())
  justificado  Boolean    @default(false)
  asistenciaId String
  aprendizId   String
  aprendiz     User       @relation(fields: [aprendizId], references: [id], onDelete: Cascade)
  asistencia   Asistencia @relation(fields: [asistenciaId], references: [id], onDelete: Cascade)
  excusas      Excusa[]

  @@unique([asistenciaId, aprendizId])
}

model Excusa {
  id                   String              @id @default(cuid())
  fechas               String
  motivo               String
  archivosUrls         String?
  estado               String              @default("Pendiente")
  respuesta            String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @default(now()) @updatedAt
  respondedAt          DateTime?
  aprendizId           String
  materiaId            String
  registroAsistenciaId String?
  aprendiz             User                @relation(fields: [aprendizId], references: [id], onDelete: Cascade)
  materia              Materia             @relation(fields: [materiaId], references: [id], onDelete: Cascade)
  registroAsistencia   RegistroAsistencia? @relation(fields: [registroAsistenciaId], references: [id], onDelete: SetNull)

  @@index([aprendizId])
  @@index([materiaId])
  @@index([estado])
}

model MateriaEvitada {
  id         String   @id @default(cuid())
  aprendizId String
  materiaId  String
  createdAt  DateTime @default(now())
  aprendiz   User     @relation(fields: [aprendizId], references: [id], onDelete: Cascade)
  materia    Materia  @relation(fields: [materiaId], references: [id], onDelete: Cascade)

  @@unique([aprendizId, materiaId])
}

model SnakeScore {
  id        String   @id @default(cuid())
  score     Int
  updatedAt DateTime @default(now()) @updatedAt
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BreakoutScore {
  id        String   @id @default(cuid())
  score     Int
  updatedAt DateTime @default(now()) @updatedAt
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FlappyScore {
  id        String   @id @default(cuid())
  score     Int
  updatedAt DateTime @default(now()) @updatedAt
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TowerScore {
  id        String   @id @default(cuid())
  score     Int
  updatedAt DateTime @default(now()) @updatedAt
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReactionScore {
  id        String   @id @default(cuid())
  score     Int
  updatedAt DateTime @default(now()) @updatedAt
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MemoryScore {
  id        String   @id @default(cuid())
  score     Int
  updatedAt DateTime @default(now()) @updatedAt
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WordleScore {
  id        String   @id @default(cuid())
  score     Int
  updatedAt DateTime @default(now()) @updatedAt
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SnakeSkin {
  id          String      @id @default(cuid())
  name        String      @unique
  description String
  price       Float
  rarity      String
  headColor   String
  bodyColor   String
  pattern     String
  trailEffect String?
  eyeStyle    String      @default("normal")
  isDefault   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  orders      SkinOrder[]
  userSkins   UserSkin[]
}

model UserSkin {
  id         String    @id @default(cuid())
  userId     String
  skinId     String
  equipped   Boolean   @default(false)
  unlockedAt DateTime  @default(now())
  skin       SnakeSkin @relation(fields: [skinId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, skinId])
}

model SkinOrder {
  id            String    @id @default(cuid())
  userId        String
  skinId        String
  amount        Float
  currency      String    @default("COP")
  status        String
  paymentMethod String?
  externalId    String?
  preferenceId  String?
  createdAt     DateTime  @default(now())
  approvedAt    DateTime?
  skin          SnakeSkin @relation(fields: [skinId], references: [id])

  @@index([userId])
  @@index([externalId])
}
